{
  "dependencies": {
    "@effect/platform": "0.94.5",
    "@effect/platform-bun": "0.87.1",
    "effect": "3.19.19"
  },
  "devDependencies": {
    "lefthook": "2.1.2"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "name": "rekooh-opinionated-lib",
  "private": true,
  "scripts": {
    "check": "biome check --write src/",
    "effect:diagnose": "effect-language-service diagnostics --project tsconfig.json",
    "effect:quickfixes": "effect-language-service quickfixes --project tsconfig.json",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "lint": "biome lint src/",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "validate": "bun run typecheck && bun run lint && bun run format:check && bun run test"
  },
  "type": "module",
  "version": "0.1.0"
}
